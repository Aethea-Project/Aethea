# =============================================
# Docker Compose Environment Variables
# Copy this to .env and fill in your values
# =============================================

# --- Data Stores ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aethea_local
DB_PORT=5432
REDIS_PORT=6379
REDIS_PASSWORD=redispass

# --- Application Ports ---
BACKEND_PORT=3001
WEB_PORT=5173

# --- Cloudflare Tunnel ---
# Optional override path to your Cloudflare tunnel credentials JSON file.
# Default (if not set): ./cloudflared/credentials/de687480-54da-4632-a55e-b3d1b4a8575d.json
# Example override (Windows): C:/Users/<you>/.cloudflared/de687480-54da-4632-a55e-b3d1b4a8575d.json
CLOUDFLARED_CREDENTIALS_FILE=

# --- Production Build Args (only needed for prod profile) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=https://api.aethea.me
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# --- Dev Tools (only needed for tools profile) ---
PGADMIN_EMAIL=admin@aethea.me
PGADMIN_PASSWORD=admin
