# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# ⚠️ NEVER COMMIT THIS FILE WITH REAL VALUES
# Service role key has admin access - keep it secret!
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Port 6543 = Supavisor pooler (transaction mode) — for all app queries
DATABASE_URL=postgresql://postgres.[project-ref]:password@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Port 5432 = Direct connection (session mode) — ONLY for migrations/seeding
DIRECT_URL=postgresql://postgres:password@db.[project-ref].supabase.co:5432/postgres

# ============================================
# REDIS CONFIGURATION
# ============================================
# For caching and queue management
REDIS_URL=redis://:redispass@localhost:6379

# ============================================
# JWT & AUTHENTICATION
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-minimum-32-characters-long

# ============================================
# API CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:5173,https://aethea.me,https://api.aethea.me

# Google Maps Web Service API key (restricted by backend server IP)
GOOGLE_MAPS_API_KEY=your-google-maps-web-service-api-key

# ============================================
# LLAMAPARSE OCR (free tier: 10,000 pages/month)
# ============================================
# LlamaCloud API Key (Primary for document parsing)
LLAMA_CLOUD_API_KEY=your-llamaparse-api-key
