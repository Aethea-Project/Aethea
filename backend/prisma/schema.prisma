generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  schemas    = ["auth", "public"]
  extensions = [vector]
}

model User {
  id                              String                            @id @db.Uuid
  email                           String                            @unique
  firstName                       String?                           @db.VarChar(50)
  lastName                        String?                           @db.VarChar(50)
  createdAt                       DateTime                          @default(now()) @db.Timestamptz(6)
  updatedAt                       DateTime                          @updatedAt @db.Timestamptz(6)
  accountType                     AccountType                       @default(patient)
  doctorProfile                   DoctorProfile?
  labTests                        LabTest[]
  feedbacks                       Feedback[]
  notifications                   Notification[]
  announcementReads               UserAnnouncementRead[]
  patientConditions               PatientCondition[]
  reservation_alert_subscriptions reservation_alert_subscriptions[]
  reservations                    Reservation[]
  scans                           Scan[]
  sessions                        UserSession[]
  prescriptions                   PatientPrescription[]
  auditLogsAsActor                AccessAuditLog[]                  @relation("AuditActor")
  auditLogsAsSubject              AccessAuditLog[]                  @relation("AuditSubject")

  @@map("users")
  @@schema("public")
}

model UserSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @db.Uuid
  sessionId           String    @unique @db.Uuid
  userAgent           String?
  ipAddress           String?   @db.VarChar(64)
  rememberMe          Boolean   @default(false)
  riskLevel           String    @default("low") @db.VarChar(16)
  stepUpRequired      Boolean   @default(false)
  stepUpCodeHash      String?   @db.VarChar(128)
  stepUpCodeExpiresAt DateTime? @db.Timestamptz(6)
  stepUpVerifiedAt    DateTime? @db.Timestamptz(6)
  lastSeenAt          DateTime  @default(now()) @db.Timestamptz(6)
  revokedAt           DateTime? @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastSeenAt])
  @@index([userId, revokedAt])
  @@map("user_sessions")
  @@schema("public")
}

model LabTest {
  id         String        @id @default(uuid()) @db.Uuid
  userId     String        @db.Uuid
  testName   String        @db.VarChar(120)
  category   String        @db.VarChar(80)
  value      String        @db.VarChar(120)
  unit       String        @db.VarChar(40)
  refMin     Decimal?      @db.Decimal(10, 2)
  refMax     Decimal?      @db.Decimal(10, 2)
  refText    String?       @db.VarChar(120)
  status     LabTestStatus @default(normal)
  orderIndex Int           @default(0)
  orderedBy  String        @db.VarChar(120)
  notes      String?
  measuredAt DateTime      @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @db.Timestamptz(6)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbackId String?       @db.Uuid
  feedback   Feedback?     @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([userId, measuredAt])
  @@index([feedbackId])
  @@map("lab_tests")
  @@schema("public")
}

model Scan {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  type        String       @db.VarChar(80)
  bodyPart    String       @db.VarChar(80)
  description String
  findings    String?
  radiologist String       @db.VarChar(120)
  priority    ScanPriority @default(routine)
  status      ScanStatus   @default(pending)
  reportUrl   String?
  images      Json?
  scanDate    DateTime     @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scanDate])
  @@map("scans")
  @@schema("public")
}

model Reservation {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  reason           String
  startAt          DateTime          @db.Timestamptz(6)
  status           ReservationStatus @default(scheduled)
  notes            String?
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(6)
  doctorScheduleId String            @db.Uuid
  slotIndex        Int
  endAt            DateTime          @db.Timestamptz(6)
  shareHealthData  Boolean           @default(false)
  notifyOnCancel   Boolean           @default(false)
  cancelDeadlineAt DateTime          @db.Timestamptz(6)
  feedbackSubmitted Boolean          @default(false)
  doctorSchedule   DoctorSchedule    @relation(fields: [doctorScheduleId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([doctorScheduleId, slotIndex])
  @@index([userId, startAt])
  @@map("reservations")
  @@schema("public")
}

model DoctorProfile {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @unique @db.Uuid
  firstName  String           @db.VarChar(50)
  lastName   String           @db.VarChar(50)
  specialty  String           @db.VarChar(120)
  bio        String?
  clinicName String?          @db.VarChar(200)
  address    String?          @db.VarChar(300)
  locationUrl String?         @db.VarChar(1000)
  city       String?          @db.VarChar(100)
  photoUrl   String?
  consultFee Int?
  languages  String[]         @default([])
  savedClinics Json?
  verified   Boolean          @default(false)
  createdAt  DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @db.Timestamptz(6)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules  DoctorSchedule[]
  weeklyTemplates    DoctorWeeklyTemplate[]
  scheduleExceptions DoctorScheduleException[]
  feedbacks  DoctorFeedback[]

  @@map("doctor_profiles")
  @@schema("public")
}

model DoctorSchedule {
  id                              String                            @id @default(uuid()) @db.Uuid
  doctorProfileId                 String                            @db.Uuid
  scheduleDate                    DateTime                          @db.Date
  startAt                         DateTime                          @db.Timestamptz(6)
  endAt                           DateTime                          @db.Timestamptz(6)
  slotDurationMins                Int
  maxPatients                     Int
  isPublished                     Boolean                           @default(true)
  bookingMode                     String                            @default("slot") @db.VarChar(10)
  clinicInfo                      Json?
  createdAt                       DateTime                          @default(now()) @db.Timestamptz(6)
  updatedAt                       DateTime                          @updatedAt @db.Timestamptz(6)
  doctorProfile                   DoctorProfile                     @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  reservation_alert_subscriptions reservation_alert_subscriptions[]
  reservations                    Reservation[]
  feedbacks                       DoctorFeedback[]

  @@unique([doctorProfileId, startAt, endAt])
  @@index([scheduleDate])
  @@index([doctorProfileId, scheduleDate])
  @@map("doctor_schedules")
  @@schema("public")
}

model DoctorWeeklyTemplate {
  id               String        @id @default(uuid()) @db.Uuid
  doctorProfileId  String        @db.Uuid
  dayOfWeek        Int
  startTime        String        @db.VarChar(5)
  endTime          String        @db.VarChar(5)
  slotDurationMins Int           @default(30)
  maxCases         Int           @default(30)
  bookingMode      String        @default("slot") @db.VarChar(10)
  isActive         Boolean       @default(true)
  clinicInfo       Json?
  createdAt        DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @db.Timestamptz(6)
  doctorProfile    DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, dayOfWeek])
  @@map("doctor_weekly_templates")
  @@schema("public")
}

model DoctorScheduleException {
  id              String                @id @default(uuid()) @db.Uuid
  doctorProfileId String                @db.Uuid
  exceptionDate   DateTime              @db.Date
  type            ScheduleExceptionType
  reason          String?               @db.VarChar(200)
  startTime       String?               @db.VarChar(5)
  endTime         String?               @db.VarChar(5)
  createdAt       DateTime              @default(now()) @db.Timestamptz(6)
  doctorProfile   DoctorProfile         @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, exceptionDate])
  @@index([doctorProfileId, exceptionDate])
  @@map("doctor_schedule_exceptions")
  @@schema("public")
}


model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
  @@schema("public")
}

model SystemAnnouncement {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  body        String
  targetRoles String[] // Array of AccountType cast as strings
  expiresAt   DateTime?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  reads       UserAnnouncementRead[]

  @@map("system_announcements")
  @@schema("public")
}

model UserAnnouncementRead {
  userId         String             @db.Uuid
  announcementId String             @db.Uuid
  readAt         DateTime           @default(now()) @db.Timestamptz(6)
  
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement   SystemAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@id([userId, announcementId])
  @@map("user_announcement_reads")
  @@schema("public")
}

model Medicine {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brandNameAr      String
  brandNameEn      String?
  activeIngredient String
  rxcui            String?
  drugbankId       String?
  drugClasses      String[]
  category         String
  form             String
  manufacturer     String?
  photoUrl         String?
  isOtc            Boolean  @default(true)
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  priceOld         Decimal? @db.Decimal(10, 2)
  priceNew         Decimal? @db.Decimal(10, 2)
  strength         String?
  packSize         Int?
  packUnit         String?
  barcode          String?
  origin           String?  @default("local")
  prescriptions    PatientPrescription[]

  @@index([activeIngredient])
  @@index([barcode])
  @@map("medicines")
  @@schema("public")
}

model DrugbankDrug {
  drugbankId        String   @id
  name              String
  synonyms          Json     @default("[]")
  categories        Json     @default("[]")
  contraindications String?
  interactions      Json     @default("[]")
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  @@index([name])
  @@map("drugbank_drugs")
  @@schema("public")
}

model PatientCondition {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId  String   @db.Uuid
  condition  String
  source     String   @default("manual")
  detectedAt DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation(fields: [patientId], references: [id], onDelete: Cascade, map: "patient_conditions_patientid_fkey")

  @@unique([patientId, condition], map: "patient_conditions_patientid_condition_key")
  @@map("patient_conditions")
  @@schema("public")
}

model PatientPrescription {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String    @db.Uuid
  medicineId  String    @db.Uuid
  doctorId    String?   @db.Uuid
  dosage      String?
  frequency   String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  patient     User      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicine    Medicine  @relation(fields: [medicineId], references: [id], onDelete: Restrict)

  @@index([patientId, isActive])
  @@map("patient_prescriptions")
  @@schema("public")
}

